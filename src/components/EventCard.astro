---
import type { EnrichedEvent } from "../lib/events";

interface Props {
  event: EnrichedEvent;
}

const { event } = Astro.props;
---

<article class="event-card" id={`evento-${event.id}`}>
  <a class="poster-link" href={event.poster} target="_blank" rel="noreferrer" aria-label={`Ver cartel de ${event.title}`}>
    <img src={event.poster} alt={`Cartel de ${event.title}`} loading="lazy" />
  </a>
  <div class="event-body">
    <div class="event-meta">
      <a class="event-date" href={event.calendarUrl} target="_blank" rel="noreferrer">{event.dateLabel}</a>
      <a class="event-venue" href={event.venue.mapsUrl} target="_blank" rel="noreferrer">{event.locationLabel}</a>
    </div>
    <h3>{event.title}</h3>
    {event.company && event.companySlug && (
      <p class="event-company">
        <a href={`/companias/${event.companySlug}/`}>{event.company}</a>
      </p>
    )}
    <p class="event-address">{event.venue.address}</p>
    <div class="event-actions">
      <a href={`/ubicaciones/${event.venueSlug}/`}>Ver sala</a>
      {event.sourceUrl && event.sourceUrl !== event.ticketUrl && (
        <a href={event.sourceUrl} target="_blank" rel="noreferrer">Ficha</a>
      )}
      {event.ticketUrl && (
        <a class="ticket-link" href={event.ticketUrl} target="_blank" rel="noreferrer">Entradas</a>
      )}
    </div>
  </div>
</article>
