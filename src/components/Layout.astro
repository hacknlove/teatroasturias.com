---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  structuredData?: Array<Record<string, unknown>>;
}

const {
  title = "Teatro Asturias",
  description = "Grupo de WhatsApp para compartir eventos y hablar de teatro en Asturias.",
  noindex = false,
  structuredData = [],
} = Astro.props;

const site = Astro.site ?? "https://teatroasturias.com";
const home = new URL("/", site);
const canonical = new URL(Astro.url.pathname, site);
const image = new URL("/images/teatro-asturias-comunidad-interior.jpg", canonical);
const imageAlt = "Interior de un teatro con patio de butacas y escenario iluminado.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Teatro Asturias",
    url: home.href,
    inLanguage: "es",
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Teatro Asturias",
    url: home.href,
    description,
    image: image.href,
  },
  ...structuredData,
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex,follow" /> : <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1672" />
    <meta property="og:image:height" content="941" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />
    {!noindex && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <slot />
  </body>
</html>
