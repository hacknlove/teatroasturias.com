---
import Layout from "../../components/Layout.astro";
import GroupList from "../../components/GroupList.astro";
import { getLocationGroups } from "../../lib/events";

const locations = getLocationGroups();
---

<Layout title="Ubicaciones | Teatro Asturias" description="Salas y espacios teatrales de Asturias con obras agrupadas por ubicación.">
  <main>
    <section class="page-heading">
      <p class="kicker">Ubicaciones</p>
      <h1>Salas y espacios</h1>
    </section>
    <GroupList groups={locations} basePath="/ubicaciones" />
  </main>
</Layout>
