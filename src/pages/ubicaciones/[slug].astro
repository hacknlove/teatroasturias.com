---
import Layout from "../../components/Layout.astro";
import EventSection from "../../components/EventSection.astro";
import { getLocationGroups, splitEvents } from "../../lib/events";

export function getStaticPaths() {
  return getLocationGroups().map((group) => ({
    params: { slug: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
const { upcoming, past } = splitEvents(group.events);
---

<Layout title={`${group.name} | Teatro Asturias`} description={`Obras en ${group.name}: cartelera, fechas, carteles y entradas.`}>
  <main>
    <section class="page-heading">
      <p class="kicker">Ubicación</p>
      <h1>{group.name}</h1>
      {group.subtitle && <p>{group.subtitle}</p>}
      {group.mapsUrl && <a class="text-link" href={group.mapsUrl} target="_blank" rel="noreferrer">Abrir en Google Maps</a>}
    </section>
    <EventSection title="Próximas obras" events={upcoming} empty="No hay próximas obras para esta ubicación." />
    <EventSection title="Obras pasadas" events={past} empty="No hay obras pasadas para esta ubicación." />
  </main>
</Layout>
