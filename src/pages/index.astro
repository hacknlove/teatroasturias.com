---
import { Image } from "astro:assets";
import Layout from "../components/Layout.astro";
import heroImage from "../assets/teatro-asturias-comunidad-interior.jpg";

const whatsappUrl = "https://chat.whatsapp.com/F4bMX5HpS0o5gTRCZ9EpGs";
---

<Layout
  title="Teatro Asturias | Grupo de WhatsApp"
  description="Teatro Asturias es un grupo de WhatsApp para compartir eventos y conversar sobre teatro en Asturias."
>
  <main class="landing">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" aria-hidden="true">
        <Image
          src={heroImage}
          alt=""
          format="webp"
          quality={82}
          fetchpriority="high"
          loading="eager"
        />
      </div>
      <div class="hero-content">
        <p class="kicker">Grupo de WhatsApp</p>
        <h1 id="hero-title">Teatro Asturias</h1>
        <p>
          Un punto de encuentro para compartir eventos, hablar de teatro y estar en contacto con la comunidad teatral asturiana.
        </p>
        <a class="primary-action" href={whatsappUrl} target="_blank" rel="noreferrer">
          Entrar en el grupo
        </a>
      </div>
    </section>
  </main>
</Layout>
